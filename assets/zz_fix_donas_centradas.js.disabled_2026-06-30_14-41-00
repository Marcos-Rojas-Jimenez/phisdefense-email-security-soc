/* =========================================================
   PhisDefense Dashboard - Fix global Plotly Pie/Donut charts
   Centra donas y mueve leyendas abajo para evitar desplazamiento.
   ========================================================= */

(function () {
  function fixDonutChart(gd) {
    if (!gd || !gd.data || !gd.layout) return;

    const pieIndexes = [];

    gd.data.forEach(function (trace, idx) {
      if (!trace) return;

      const isPie = trace.type === "pie";
      const isDonut = isPie && trace.hole && trace.hole > 0;

      if (isPie || isDonut) {
        pieIndexes.push(idx);
      }
    });

    if (pieIndexes.length === 0) return;

    try {
      const domainX = [];
      const domainY = [];

      pieIndexes.forEach(function () {
        domainX.push([0.08, 0.92]);
        domainY.push([0.12, 0.88]);
      });

      Plotly.restyle(gd, {
        "domain.x": domainX,
        "domain.y": domainY,
        "textposition": pieIndexes.map(() => "inside"),
        "textinfo": pieIndexes.map(() => "percent")
      }, pieIndexes);

      Plotly.relayout(gd, {
        "autosize": true,
        "margin.l": 10,
        "margin.r": 10,
        "margin.t": 45,
        "margin.b": 80,
        "legend.orientation": "h",
        "legend.x": 0.5,
        "legend.xanchor": "center",
        "legend.y": -0.18,
        "legend.yanchor": "top",
        "legend.font.size": 11
      });
    } catch (e) {
      console.warn("PhisDefense donut centering patch skipped:", e);
    }
  }

  function fixAllDonuts() {
    const graphs = document.querySelectorAll(".js-plotly-plot");
    graphs.forEach(function (gd) {
      fixDonutChart(gd);
    });
  }

  function installPlotlyHooks() {
    document.querySelectorAll(".js-plotly-plot").forEach(function (gd) {
      if (gd.__phisdefense_donut_hooked) return;
      gd.__phisdefense_donut_hooked = true;

      gd.on && gd.on("plotly_afterplot", function () {
        setTimeout(function () {
          fixDonutChart(gd);
        }, 50);
      });
    });
  }

  function run() {
    fixAllDonuts();
    installPlotlyHooks();
  }

  document.addEventListener("DOMContentLoaded", function () {
    setTimeout(run, 500);
    setTimeout(run, 1500);
    setTimeout(run, 3000);
  });

  const observer = new MutationObserver(function () {
    setTimeout(run, 300);
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });

  window.addEventListener("resize", function () {
    setTimeout(run, 300);
  });
})();
